<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:background="@color/bottom_nav_pink"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_auth_social_button"
                android:gravity="center"
                android:text="S"
                android:textColor="@color/bottom_nav_pink"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stylish Store"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="⌕"
                android:textColor="@color/white"
                android:textSize="34sp" />

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="●"
                android:textColor="@color/white"
                android:textSize="24sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="172dp"
            android:layout_marginStart="26dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="26dp"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:text="Featured Products"
            android:textColor="@color/stylish_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:text="Categories"
            android:textColor="@color/stylish_text"
            android:textSize="21sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:text="Ice"
                android:textColor="@color/stylish_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:text="Hot"
                android:textColor="@color/stylish_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:text="Tea"
                android:textColor="@color/stylish_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_pink"
                android:gravity="center"
                android:text="Frappe"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            android:text="Promotion"
            android:textColor="@color/stylish_text"
            android:textSize="21sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:text="50% OFF\nPrice 5$ up"
                android:textColor="@color/stylish_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:text="50% OFF\nPrice 2$ up"
                android:textColor="@color/stylish_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:text="50% OFF\nNew Deal"
                android:textColor="@color/stylish_text"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
