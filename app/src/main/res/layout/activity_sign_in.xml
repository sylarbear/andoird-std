<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/rootSignIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="812dp"
        android:orientation="vertical"
        android:paddingStart="29dp"
        android:paddingTop="63dp"
        android:paddingEnd="29dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:text="Welcome\nBack!"
            android:textColor="@color/stylish_text"
            android:textSize="34sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inputUsername"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_input"
            android:drawableStart="@drawable/ic_user_16"
            android:drawablePadding="12dp"
            android:hint="Username or Email"
            android:inputType="textEmailAddress"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:singleLine="true"
            android:textColor="@color/stylish_text"
            android:textColorHint="#676767"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/inputPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="31dp"
            android:background="@drawable/bg_input"
            android:drawableStart="@drawable/ic_lock_16"
            android:drawableEnd="@drawable/ic_eye_16"
            android:drawablePadding="12dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:singleLine="true"
            android:textColor="@color/stylish_text"
            android:textColorHint="#676767"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/textForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="end|center_vertical"
            android:text="Forgot Password?"
            android:textColor="@color/stylish_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/buttonLogin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_primary_button"
            android:gravity="center"
            android:text="Login"
            android:textColor="@color/white"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="105dp"
            android:gravity="center"
            android:text="- OR Continue with -"
            android:textColor="#575757"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_auth_social_button"
                android:gravity="center"
                android:text="G"
                android:textColor="@color/stylish_google"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_auth_social_button"
                android:contentDescription="@null"
                android:padding="15dp"
                android:src="@drawable/ic_apple_24" />

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_auth_social_button"
                android:gravity="center"
                android:text="f"
                android:textColor="@color/stylish_facebook"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutSignUp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create An Account "
                android:textColor="#575757"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="Sign Up"
                android:textColor="@color/stylish_primary"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
